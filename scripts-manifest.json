{
  "version": "2",
  "description": "脚本位置分布映射表。移动后统一存放在使用的 skill 下，避免重复副本。",
  "root_scripts": {
    "path": "scripts/",
    "entries": {
      "common.sh": "共享函数库（被各 skill 的 run_tasks.sh source 引入）",
      "check-agent-status.sh": "Agent 健康检查（multica CLI）"
    }
  },
  "skills": [
    {
      "name": "linglong-binary-runner",
      "path": "skills/linglong-binary-runner/",
      "shared_scripts": ["common.sh"],
      "private_scripts": ["run_tasks.sh", "validate_projects.sh"]
    },
    {
      "name": "linglong-source-updater",
      "path": "skills/linglong-source-updater/",
      "shared_scripts": ["common.sh"],
      "private_scripts": ["run_tasks.sh", "download-and-checksum.sh", "update-linglong-yaml.py", "validate-linglong-yaml.py"]
    },
    {
      "name": "linyaps-multica-packer-dispatch",
      "path": "skills/linyaps-multica-packer-dispatch/",
      "scripts": {
        "shared": ["common.sh", "check-agent-status.sh"],
        "private": ["csv_to_json.sh", "detect_init_source.sh", "dispatch.sh"]
      }
    },
    {
      "name": "linyaps-packaging-precheck",
      "path": "skills/linyaps-packaging-precheck/",
      "scripts": {
        "shared": ["common.sh"],
        "private": ["precheck.sh", "query_upstream.sh"]
      }
    },
    {
      "name": "linyaps-packaging-report",
      "path": "skills/linyaps-packaging-report/",
      "scripts": {
        "shared": ["common.sh"],
        "private": ["status_upload.sh", "status_upload_initOnly.sh", "verify_upload.sh"]
      }
    }
  ]
}